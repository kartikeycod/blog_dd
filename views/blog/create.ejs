<!DOCTYPE html>
<html>

<head>

    <title>Create Blog</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 40px;
        }

        .container {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 40px rgba(0, 0, 0, .2);
            width: 700px;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
            color: #4f46e5;
        }

        input,
        textarea {
            width: 100%;
            padding: 15px;
            margin-top: 10px;
            border: 1px solid #ccc;
            border-radius: 10px;
            font-size: 16px;
        }

        input[type=file] {
            padding: 10px;
        }

        button {
            margin-top: 20px;
            width: 100%;
            padding: 15px;
            background: #4f46e5;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 17px;
            cursor: pointer;
        }

        button:hover {
            background: #372fd4;
        }
    </style>

</head>

<body>

    <div class="container">

        <h1>Create Blog</h1>

        <form action="/blogs/create" method="POST" enctype="multipart/form-data">

            <input type="text" name="title" placeholder="Title" required>

            <br><br>

            <input type="text" name="category" placeholder="Category" required>

            <br><br>

            <input type="file" name="image" accept=".jpg,.jpeg,.png">

            <br><br>

            <textarea name="content" rows="12" cols="70" placeholder="Write Blog" required>

</textarea>

            <br><br>

            <button>

                Create Blog

            </button>

        </form>

    </div>

</body>

</html>