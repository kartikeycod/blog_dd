<!DOCTYPE html>
<html>

<head>

    <title>
        <%= blog.title %>
    </title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Poppins, sans-serif;
        }

        body {
            background: #f5f5f5;
            padding: 50px;
        }

        .container {
            max-width: 900px;
            margin: auto;
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .1);
        }

        h1 {
            color: #4f46e5;
            margin-bottom: 20px;
        }

        p {
            margin: 15px 0;
            line-height: 1.8;
        }

        img {
            width: 100%;
            max-height: 450px;
            object-fit: cover;
            border-radius: 12px;
            margin: 25px 0;
        }

        a {
            display: inline-block;
            margin-top: 30px;
            padding: 12px 25px;
            background: #4f46e5;
            color: white;
            text-decoration: none;
            border-radius: 8px;
        }

        a:hover {
            background: #372fd4;
        }
    </style>

</head>

<body>

    <div class="container">

        <h1>

            <%= blog.title %>

        </h1>

        <p>

            Author :
            <%= blog.User.name %>

        </p>

        <p>

            Category :
            <%= blog.category %>

        </p>

        <% if(blog.image){ %>

            <img src="<%= blog.image %>" width="400">

            <% } %>

                <hr><br>

                <p>

                    <%= blog.content %>

                </p>

                <br>

                <a href="/blogs">

                    Back

                </a>

    </div>

</body>

</html>